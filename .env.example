# ParaNet 环境变量配置
# 复制本文件为 .env 后填入实际值：cp .env.example .env

# ---- API ----
PARANET_API_HOST=0.0.0.0
PARANET_API_PORT=8000

# ---- 数据库 ----
# SQLite 数据目录，默认 backend/data（留空使用默认值）
# PARANET_DATA_DIR=

# ---- JWT 认证 ----
# 生产环境务必更换
PARANET_JWT_SECRET=paranet-jwt-secret-change-in-production

# ---- Editor 后端 ----
# PARANET_EDITOR_BACKEND_URL=http://localhost:8080/api
PARANET_USE_MOCK=true

# ---- LLM（Agent 对话） ----
# 智谱 GLM / OpenAI 兼容 API 配置，填入你的 API Key
PARANET_LLM_MODEL=glm-4-flash
PARANET_LLM_API_KEY=
PARANET_LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# ---- Agent ----
PARANET_AGENT_MAX_ITERATIONS=8
# PARANET_RUNTIME=local
